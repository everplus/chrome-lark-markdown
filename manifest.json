{
  "manifest_version": 3,
  "name": "Feishu Doc to Markdown",
  "version": "1.0.0",
  "description": "Extract Feishu/Lark document content and convert to Markdown with preview and save",
  "permissions": ["activeTab", "tabs", "scripting", "storage", "debugger"],
  "host_permissions": [
    "*://*.feishu.cn/*",
    "*://*.feishu-3rd-party-services.com/*",
    "*://*.larksuite.com/*",
    "*://*.larkenterprise.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.feishu.cn/*",
        "*://*.feishu-3rd-party-services.com/*",
        "*://*.larksuite.com/*",
        "*://*.larkenterprise.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
